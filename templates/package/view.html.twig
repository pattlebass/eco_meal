{% extends 'base.html.twig' %}

{% block title %}{{ package.name }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col">
            <h1 class="package-name">{{ package.name }}</h1>
            <div class="d-flex gap-2 h4">
                <span class="text-muted">{{ package.price }} RON</span>
                <span>•</span>
                <a href="{{ path('app_business_view', {id: package.business.id}) }}" class="text-decoration-none">{{ package.business.name }}</a>
            </div>
            <hr>
            <p class="package-description">{{ package.description }}</p>
            <form action="{{ path('app_order_new', {id: package.id}) }}" method="POST">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-cart"></i>
                    Create Order
                </button>
            </form>
        </div>
        <div class="col">
            <img src="{{ package.photo | default("/default-image.jpg") }}" alt="" class="img-fluid rounded-5">
        </div>
    </div>
</div>

{% endblock %}
