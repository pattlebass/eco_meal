<style>
    .package a {
        color: inherit;
        text-decoration: none;
    }

    .package {
        transition: transform 0.1s;
    }

    .package:hover {
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 6px 20px rgba(27, 67, 50, 0.14);
    }

    .package .card-text {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

{% for package in packages %}
    <div class="col-lg-4 col-sm-6">
        {% include "package/_package.html.twig" with {package: package} %}
    </div>
{% else %}
    <div class="col">
        <p class="text-muted">No matching packages.</p>
    </div>
{% endfor %}
