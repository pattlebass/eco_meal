{% extends 'base.html.twig' %}

{% block title %}Hello BusinessController!{% endblock %}

{% block body %}
    <style>
        * {
            box-sizing: border-box;
        }

        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }

        .grid {
            display: grid;
            gap: 30px 20px;
            grid-template-columns: 1fr 1fr 1fr;
        }

        .package a {
            color: inherit;
            text-decoration: none;
        }

        .package-image {
            width: 100%;
            height: auto;
        }

        .package-name {
            margin: 0;
            font-size: 20px;
        }

        .package-description {
            margin: 0;
        }
    </style>

    <a href="{{ path('app_package_new') }}">Create new</a>

    <div class="example-wrapper">
        <div class="grid">
            {% for package in packages %}
                <article class="package">
                    <a href="{{ path('app_package_view', {id: package.id}) }}">
                        <img src="{{ package.photo | default("/default-image.jpg") }}" alt="" class="package-image">
                        <h1 class="package-name">{{ package.name }}</h1>
                        <p class="package-description">{{ package.description }}</p>
                    </a>
                </article>
            {% endfor %}
        </div>
    </div>
{% endblock %}
