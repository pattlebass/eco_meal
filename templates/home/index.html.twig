{% extends "base.html.twig" %}

{% block body %}
    <style>
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        main {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .outer-p-container {
            mask-image: linear-gradient(
                to right,
                transparent,
                black 10%,
                black 90%,
                transparent
            );
            overflow: hidden;
        }

        .packages-container {
            width: max-content;
            animation: scroll-package 20s infinite linear;
        }

        .packages-container:hover {
            animation-play-state: paused;
        }

        .package {
            flex-shrink: 0;
            width: 150px;
        }

        .package:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 6px 20px rgba(27, 67, 50, 0.14);
        }

        .package a {
            color: inherit;
            text-decoration: none;
        }

        .package .card-title {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .package .card-text {
            display: none;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        @keyframes scroll-package {
            0% {
                transform: translateX(0);
            }
            100% {
                transform: translateX(-50%);
            }
        }
    </style>
    <main class="container">
        <div class="row text-center">
            <div class="col-lg-8 mx-auto">
                <h1>Welcome to Eco Meal!</h1>
                <p class="lead">Save Food. Save Money.</p>
            </div>
        </div>
        {% if packages|length > 4 %}
            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6 outer-p-container">
                    <div class="packages-container py-4 d-flex gap-4">
                        {% for package in packages|slice(0, 4) %}
                            {% include "package/_package.html.twig" %}
                        {% endfor %}
                        {% for package in packages|slice(0, 4) %}
                            {% include "package/_package.html.twig" %}
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% endif %}
        <div class="row justify-content-center mt-4">
            <div class="col-auto">
                <a href="{{ path('app_package') }}" class="btn btn-success">
                    <i class="bi bi-fork-knife"></i>
                    View All Packages
                </a>
            </div>
        </div>
    </main>
{% endblock %}
