{% extends 'base.html.twig' %}

{% block title %}{{ business.name }}{% endblock %}

{% block body %}

<style>
    .btn-favorite {
        color: #dc3545;
        border-color: #dc3545;
    }

    .btn-favorite:hover {
        color: white;
        background-color: #dc3545;
    }
</style>

<main class="container mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="row">
                <div class="col mx-auto">
                    <h1>{{ business.name }}</h1>
                    <p class="text-muted">{{ business.businessType.name }}</p>
                    <hr>
                </div>
            </div>
            <div class="row justify-content-center">
                <div class="col">
                    {% if is_granted('ROLE_CONSUMER') and app.user.consumer %}
                        <form method="post" action="{{ path('app_business_toggle_favorite', {id: business.id}) }}">
                            <button class="btn {{ isFavorite ? 'btn-danger' : 'btn-outline-danger' }}">
                                {% if isFavorite %}
                                    <i class="bi bi-heart-fill"></i>
                                    Favorited
                                {% else %}
                                    <i class="bi bi-heart"></i>
                                    Add to Favorites
                                {% endif %}
                            </button>
                        </form>
                    {% endif %}
                    {% if is_granted('ROLE_BUSINESS') and app.user.business?.id == business.id %}
                        <a class="btn btn-secondary" href="{{ path('app_business_update_user', {id: business.id}) }}">
                            <i class="bi bi-pencil"></i>
                            Update account
                        </a>
                    {% endif %}
                    {% if is_granted('ROLE_ADMIN')%}
                        <a class="btn btn-secondary" href="{{ path('app_business_update', {id: business.id}) }}">
                            <i class="bi bi-pencil"></i>
                            Update
                        </a>
                        <form class="d-inline" method="post" action="{{ path('app_business_delete', {id: business.id}) }}">
                            <button class="btn btn-danger" type="submit">
                                <i class="bi bi-trash"></i>
                                Delete
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
            <div class="row justify-content-center mt-4">
                <div class="col">
                    <h2>Information</h2>
                    <table class="table">
                        <tr>
                            <th>Address</th>
                            <td>{{ business.street }}, {{ business.houseNumber }}, {{ business.city }}</td>
                        </tr>
                        <tr>
                            <th>Contact</th>
                            <td>{{ business.phoneNumber }}</td>
                        </tr>
                    </table>
                </div>
                {% if not is_granted("ROLE_CONSUMER") %}
                    <div class="col">
                        <div class="d-flex gap-4 align-items-center">
                            <h2>Packages</h2>
                            {% if is_granted("ROLE_BUSINESS") and app.user.business?.id == business.id %}
                                <a class="btn btn-primary" href="{{ path('app_business_new_package', {'id': business.id}) }}">
                                    <i class="bi bi-plus-lg"></i>
                                    New package
                                </a>
                            {% endif %}
                        </div>
                        {% include "business/_package_list.html.twig" %}
                    </div>
                {% endif %}
            </div>
            {% if is_granted("ROLE_CONSUMER") %}
            <div class="row g-4 mt-2">
                <h2>Available Packages</h2>
                {% include "package/_package_grid.html.twig" with {packages: packages} %}
            </div>
            {% endif %}
        </div>
    </div>
</main>

<script>
    function deletePackage(path) {
        fetch(path, {method: "POST"})
            .then(response => {
                if (response.redirected) {
                    window.location.href = response.url;
                }
            });
    }
</script>

{% endblock %}
