{% extends 'base.html.twig' %}

{% block title %}{{ business.name }}{% endblock %}

{% block body %}

<style>
    .btn-favorite {
        color: #dc3545;
        border-color: #dc3545;
    }

    .btn-favorite:hover {
        color: white;
        background-color: #dc3545;
    }
</style>

<main class="container mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1>{{ business.name }}</h1>
            <p class="text-muted">{{ business.businessType.name }}</p>
            <hr>
        </div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-8">
            {% if is_granted('ROLE_CONSUMER') and app.user.consumer %}
                <form method="post" action="{{ path('app_business_toggle_favorite', {id: business.id}) }}">
                    <button class="btn {{ isFavorite ? 'btn-danger' : 'btn-outline-danger' }}">
                        {% if isFavorite %}
                            <i class="bi bi-heart-fill"></i>
                            Favorited
                        {% else %}
                            <i class="bi bi-heart"></i>
                            Add to Favorites
                        {% endif %}
                    </button>
                </form>
            {% endif %}
            {% if is_granted('ROLE_ADMIN')%}
                <a class="btn btn-secondary" href="{{ path('app_business_update', {id: business.id}) }}">Update</a>
                <button class="btn btn-favorite" onclick="deleteBusiness()">Delete</button>
            {% endif %}
        </div>
    </div>
    <div class="row justify-content-center mt-4">
        <div class="col-lg-4">
            <h2>Information</h2>
            <table class="table">
                <tr>
                    <th>Address</th>
                    <td>{{ business.street }}, {{ business.houseNumber }}, {{ business.city }}</td>
                </tr>
                <tr>
                    <th>Contact</th>
                    <td>{{ business.phoneNumber }}</td>
                </tr>
            </table>
        </div>
        <div class="col-lg-4">
            <div class="d-flex gap-4 align-items-center">
                <h2>Packages</h2>
                {% if is_granted("ROLE_BUSINESS") %}
                    <a class="btn btn-primary" href="{{ path('app_business_new_package', {'id': business.id}) }}">New package</a>
                {% endif %}
            </div>
            <ul class="list-group mt-2">
                {% for package in business.packages %}
                    <li class="list-group-item">
                        <div class="d-flex gap-2 align-items-center">
                            <a href="{{ path('app_package_view', {id: package.id}) }}" class="flex-fill">{{ package.name }}</a>

                            {% if app.user.id == business.user.id or is_granted('ROLE_ADMIN')%}
                                <a href="{{ path('app_business_update_package', {id: business.id, packageId: package.id}) }}" class="btn btn-secondary">Update</a>
                                <button onclick="deletePackage('{{ path('app_package_delete', {id: package.id}) }}')" class="btn btn-danger">Delete</button>
                            {% endif %}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </div>
</main>

<script>
    function deleteBusiness() {
        fetch("{{ path('app_business_delete', {id: business.id}) }}", {method: "POST"})
            .then(response => {
                if (response.redirected) {
                    window.location.href = response.url;
                }
            });
    }
    function deletePackage(path) {
        fetch(path, {method: "POST"})
            .then(response => {
                if (response.redirected) {
                    window.location.href = response.url;
                }
            });
    }
</script>

{% endblock %}
