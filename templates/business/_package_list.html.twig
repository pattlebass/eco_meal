<ul class="list-group mt-2">
    {% for package in business.packages %}
        <li class="list-group-item">
            <div class="d-flex gap-2 align-items-center">
                <a href="{{ path('app_package_view', {id: package.id}) }}" class="flex-fill">{{ package.name }}</a>

                {% if app.user.id == business.user.id %}
                    <a href="{{ path('app_business_update_package', {id: business.id, packageId: package.id}) }}" class="btn btn-outline-secondary">
                        <i class="bi bi-pencil"></i>
                    </a>

                    <button onclick="deletePackage('{{ path('app_package_delete', {id: package.id}) }}')" class="btn btn-outline-danger">
                        <i class="bi bi-trash"></i>
                    </button>
                {% endif %}
            </div>
        </li>
    {% endfor %}
</ul>
